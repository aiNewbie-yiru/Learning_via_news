.state {
  padding: 80rpx 24rpx;
  color: #667085;
  text-align: center;
}

.error {
  color: #b42318;
}

.topic-tabs {
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.topic-tab {
  display: inline-flex;
  max-width: 360rpx;
  margin-right: 16rpx;
  padding: 14rpx 22rpx;
  border: 1rpx solid #d0d5dd;
  border-radius: 8rpx;
  background: #fff;
  color: #344054;
  font-size: 26rpx;
}

.topic-tab.active {
  border-color: #1d4ed8;
  color: #1d4ed8;
}

.article,
.word-card {
  border-radius: 8rpx;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(16, 24, 40, 0.06);
}

.article {
  padding: 30rpx;
}

.source {
  display: block;
  color: #667085;
  font-size: 24rpx;
}

.title {
  display: block;
  margin-top: 12rpx;
  color: #101828;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.25;
}

.content {
  display: block;
  margin-top: 24rpx;
  color: #344054;
  font-size: 30rpx;
  line-height: 1.7;
  white-space: pre-wrap;
}

.vocab {
  margin-top: 28rpx;
}

.section-title {
  display: block;
  margin-bottom: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.word-card {
  margin-bottom: 16rpx;
  padding: 24rpx;
}

.word {
  display: block;
  color: #101828;
  font-size: 32rpx;
  font-weight: 700;
}

.definition {
  display: block;
  margin-top: 8rpx;
  color: #475467;
  font-size: 26rpx;
  line-height: 1.5;
}

